# Server Configuration
NODE_ENV=development
PORT=3000

# Admin Authentication (REQUIRED - change this!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your-secure-admin-key-change-me-please

# Database (Optional - for production)
# Get free PostgreSQL from https://neon.tech or https://supabase.com
DATABASE_URL=postgresql://localhost:5432/widget_db
USE_REAL_DB=false

# Redis (Optional - for production)
# Get free Redis from https://upstash.com
REDIS_URL=redis://localhost:6379
USE_REAL_REDIS=false

# Widget Configuration
DEFAULT_WIDGET_TITLE=Рекомендуем для вас
DEFAULT_PRIMARY_COLOR=#3B82F6
DEFAULT_POSITION=bottom-right
DEFAULT_MAX_PRODUCTS=5

# Security
IP_SALT=your-random-salt-here-change-me
SESSION_SECRET=your-session-secret-here-change-me

# CORS
ALLOWED_ORIGINS=*

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
LOG_TO_CONSOLE=true

# Features
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600
ENABLE_ANALYTICS=true
